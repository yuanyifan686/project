# 复制为 backend/.env 用于本地开发
# Render 部署请在控制台 Environment 中配置，勿提交 .env

# 服务
HOST=127.0.0.1
PORT=8000

# 管理后台（生产务必修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-random-jwt-secret
JWT_EXPIRE_HOURS=24

# CORS（逗号分隔，生产填 Render 域名）
# ALLOWED_ORIGINS=https://你的服务.onrender.com

# 首次启动自动写入种子数据（Render 建议 true）
SEED_ON_STARTUP=true

# Coze AI（可选）
COZE_API_KEY=
COZE_BOT_ID=
COZE_API_BASE=https://api.coze.cn